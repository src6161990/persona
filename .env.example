# === LLM 프로바이더 선택 ===
# 프로바이더 교체는 이 두 값만 바꾸면 된다 (코드 수정 불필요).
# provider: anthropic / openai / azure_openai / google_genai ...
# (anthropic 외 프로바이더는 통합 패키지 설치 필요: 예) uv sync --extra openai)
PERSONA_MODEL_PROVIDER=databricks
# 모델(또는 Azure 배포명). 예) openai: gpt-4.1 / azure_openai: <deployment-name>
PERSONA_MODEL_NAME=databricks-claude-opus-4-6
# 모델 최대 출력 토큰 수
PERSONA_MAX_TOKENS=16000

# === 프로바이더별 자격증명 (선택한 프로바이더 것만 채우면 됨) ===
# Anthropic (기본)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Azure OpenAI (PERSONA_MODEL_PROVIDER=azure_openai, MODEL_NAME=<deployment>)
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
OPENAI_API_VERSION=""

# Databricks (PERSONA_MODEL_PROVIDER=databricks, PERSONA_MODEL_NAME=<serving-endpoint-name>)
# 설치: uv sync --extra databricks
DATABRICKS_WORKSPACE_URL=""
DATABRICKS_CLIENT_ID=""
DATABRICKS_CLIENT_SECRET=""
